# ============================================================================
# Variables de entorno — Fresafit CRM
# Copia este archivo a `.env.local` y rellena con los valores de tu proyecto
# Supabase (Project Settings → API). En Vercel, configúralas en el proyecto.
# ============================================================================

# URL y anon key (públicas: van al navegador, protegidas por RLS).
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Service role key: scripts locales (seed / import) y la integración con
# Tienda Nube (webhooks y sincronización corren sin sesión de usuario).
# NUNCA la subas al repo ni la expongas en el navegador.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Tienda Nube: credenciales de la app privada (portal de socios → Aplicaciones
# → tu app → Llaves de acceso). El client secret también firma los webhooks.
TIENDANUBE_CLIENT_ID=tu-app-id
TIENDANUBE_CLIENT_SECRET=tu-client-secret

# Token que Vercel manda en el header del cron de sincronización diaria
# (Settings → Environment Variables). Genera uno: `openssl rand -hex 24`.
CRON_SECRET=un-token-aleatorio-largo
